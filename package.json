{
  "name": "kaoruko-bot-next",
  "version": "1.0.0",
  "description": "Kaoruko is a Discord bot with many commands",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "node dist/index.js",
    "dev": "node scripts/dev.js",
    "watch": "bun exec tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist node_modules",
    "lint": "bun exec @biomejs/biome check .",
    "lint:fix": "bun exec @biomejs/biome check --apply .",
    "format": "bun exec @biomejs/biome format --write .",
    "postinstall": "tsc"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "discord.js": "^14.26.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "module-alias": "^2.3.4",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "npm"
  ],
  "author": "Kaoruko Bot Team",
  "license": "MIT"
}
